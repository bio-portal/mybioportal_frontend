---
import Layout from '../../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Live Cohort Explorer | BioPortal"
  navType="minimal"
  backLink="/data"
  backText="Back to Data Access"
>
  <div class="absolute top-0 inset-x-0 h-[500px] bg-gradient-to-b from-brand-blue-deep/10 via-brand-teal/5 to-transparent -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 py-8 min-h-[calc(100vh-14rem)] flex flex-col lg:flex-row gap-8 items-start">

    <aside class="w-full lg:w-72 bg-white rounded-3xl p-6 border border-gray-100 shadow-xl shadow-gray-100/30 shrink-0 lg:sticky lg:top-28">
      <div class="mb-6">
        <label class="block text-[10px] uppercase tracking-widest font-black text-gray-400 mb-4 bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-100">Cohort Slices</label>
        <div id="filter-list" class="space-y-1.5 max-h-[300px] lg:max-h-[550px] overflow-y-auto pr-1">
          <button id="btn-baseline" class="w-full text-left px-4 py-3 rounded-xl text-xs font-bold transition-all bg-brand-dark/5 text-brand-dark border-l-4 border-brand-dark shadow-sm">
            Baseline Cohort
          </button>
          <div id="filter-loading" class="text-xs text-center text-gray-400 py-4 font-medium italic">Syncing filter matrix...</div>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-50 flex flex-col gap-2 text-[11px] text-gray-400 font-medium">
        <div class="flex justify-between items-center">
          <span>API Stream: <span class="text-brand-green-bright font-bold">Active</span></span>
          <span id="cache-indicator" class="px-2 py-0.5 rounded-md bg-gray-100 font-bold uppercase tracking-wider text-[9px]">CONNECTING</span>
        </div>
      </div>
    </aside>

    <main class="flex-1 w-full">
      <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8 bg-white/40 p-6 rounded-3xl border border-white/60 backdrop-blur-md shadow-sm">
        <div>
          <h1 id="active-cohort-title" class="text-3xl font-extrabold text-gray-900 tracking-tight leading-none">Baseline Cohort</h1>
          <p class="text-xs text-gray-400 mt-2.5 font-semibold tracking-wide uppercase">Interactive Multi-Omics Visualizer</p>
        </div>
        <div class="relative w-full sm:w-80">
          <input
            type="text"
            id="chart-search"
            placeholder="Search metric cards (e.g. SBP, Ancestry)..."
            class="w-full pl-10 pr-4 py-3 rounded-2xl bg-white border border-gray-100 focus:border-brand-blue-deep focus:ring-2 focus:ring-brand-blue-deep/10 transition-all outline-none text-xs font-medium shadow-sm"
          />
          <svg class="w-4 h-4 absolute left-3.5 top-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
      </header>

      <div id="dashboard-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        </div>

      <div id="search-fallback" class="hidden flex-col items-center justify-center py-24 text-center text-gray-400 bg-white border border-gray-100 rounded-[2.5rem] shadow-sm">
        <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center text-gray-300 border border-gray-100 mb-4">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <p class="text-base font-bold text-gray-800 mb-1">No matching metrics discovered</p>
        <p class="text-xs text-gray-400 max-w-xs mx-auto">Verify your parameters or shift back to the global baseline cohort matrix.</p>
      </div>
    </main>
  </div>
</Layout>

<script>
  import Chart from 'chart.js/auto';

  // Points directly into your production Go Cloud Function API deployment Gateway
  const API_GATEWAY = "https://us-central1-bioportal-data-viewer.cloudfunctions.net/GetStats";

  let variableMetadata = [];
  let summaryStatistics = [];
  let activeFilter = 'baseline';
  let chartsMap = {};

  async function fetchFromPortal(queryString) {
    const response = await fetch(`${API_GATEWAY}?${queryString}`);
    if (!response.ok) throw new Error("API performance runtime timeout");

    // Evaluate memory caching distribution variables for diagnostic transparency
    const cacheHeader = response.headers.get("X-Cache");
    const indicator = document.getElementById("cache-indicator");
    if (indicator && cacheHeader) {
      indicator.innerText = cacheHeader;
      if (cacheHeader === "HIT") {
        indicator.className = "px-2 py-0.5 rounded-md bg-brand-green-bright/10 text-brand-green-bright font-black uppercase tracking-wider text-[9px]";
      } else {
        indicator.className = "px-2 py-0.5 rounded-md bg-brand-orange-deep/10 text-brand-orange-deep font-black uppercase tracking-wider text-[9px]";
      }
    }
    return await response.json();
  }

  async function initializeEngine() {
    try {
      const [meta, filters] = await Promise.all([
        fetchFromPortal("type=metadata"),
        fetchFromPortal("type=filters")
      ]);

      variableMetadata = meta;
      renderFilterMenu(filters);
      await loadCohortData('baseline');

      document.getElementById('chart-search').addEventListener('keyup', handleSearchQuery);
    } catch (err) {
      console.error("Dashboard engine structural sync crash:", err);
    }
  }

  function renderFilterMenu(filters) {
    const container = document.getElementById('filter-list');
    const loadingPlaceholder = document.getElementById('filter-loading');
    if (loadingPlaceholder) loadingPlaceholder.remove();

    const baselineBtn = document.getElementById('btn-baseline');
    container.innerHTML = '';
    container.appendChild(baselineBtn);
    baselineBtn.onclick = () => loadCohortData('baseline');

    filters.filter(f => f !== 'baseline').sort().forEach(fKey => {
      const btn = document.createElement('button');
      btn.id = `btn-${fKey}`;
      btn.className = "w-full text-left px-4 py-2.5 rounded-xl text-xs font-semibold text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-all border-l-4 border-transparent";

      // Transform raw snake keys into structured clean language strings
      let formattedText = fKey.replace(/_/g, ' ')
                              .replace('has ', 'With ')
                              .replace('demo ', '')
                              .replace('yes', '(Yes)')
                              .replace('no', '(No)');

      btn.innerText = formattedText.replace(/(^\w|\s\w)/g, m => m.toUpperCase());
      btn.onclick = () => loadCohortData(fKey);
      container.appendChild(btn);
    });
  }

  async function loadCohortData(filterKey) {
    document.querySelectorAll('#filter-list button').forEach(b => {
      b.className = "w-full text-left px-4 py-2.5 rounded-xl text-xs font-semibold text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-all border-l-4 border-transparent";
    });

    const activeBtn = document.getElementById(`btn-${filterKey}`);
    if (activeBtn) {
      activeBtn.className = "w-full text-left px-4 py-3 rounded-xl text-xs font-bold transition-all bg-brand-dark/5 text-brand-dark border-l-4 border-brand-dark shadow-sm";
    }

    activeFilter = filterKey;

    let headingText = filterKey === 'baseline' ? 'Baseline Cohort' : filterKey.replace(/_/g, ' ').replace(/(^\w|\s\w)/g, m => m.toUpperCase());
    document.getElementById('active-cohort-title').innerText = headingText;

    try {
      summaryStatistics = await fetchFromPortal(`filter=${filterKey}`);
      renderDashboardGrid();
    } catch (err) {
      console.error("Failed structural dataset slice updates swap:", err);
    }
  }

  function renderDashboardGrid() {
    const grid = document.getElementById('dashboard-grid');

    // Clear structural graph bindings cleanly to eliminate canvas context memory leaks
    Object.values(chartsMap).forEach(chart => chart.destroy());
    chartsMap = {};
    grid.innerHTML = '';

    variableMetadata.forEach(meta => {
      // Find row data based on the correct nested slice array contract
      const match = summaryStatistics.find(s => s.chart_id === meta.chart_id);
      if (!match) return;

      const card = document.createElement('div');
      card.className = "chart-card bg-white border border-gray-100 rounded-3xl p-5 shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 flex flex-col";
      card.setAttribute('data-title', meta.display_name);

      card.innerHTML = `
        <div class="flex justify-between items-start mb-4 border-b border-gray-50 pb-3">
          <h3 class="font-bold text-xs text-gray-800 tracking-tight">${meta.display_name}</h3>
          <span class="text-[9px] bg-brand-dark/5 text-brand-dark px-2 py-0.5 rounded-md font-bold uppercase tracking-wider">${meta.units}</span>
        </div>
        <div class="relative h-[200px] w-full">
          <canvas id="canvas-${meta.chart_id}"></canvas>
        </div>
      `;

      grid.appendChild(card);
      renderChartInstance(meta, match.data);
    });

    handleSearchQuery();
  }

  function renderChartInstance(meta, dataset) {
    const canvasElement = document.getElementById(`canvas-${meta.chart_id}`);
    if (!canvasElement) return;

    const ctx = (canvasElement as HTMLCanvasElement).getContext('2d');
    const labels = dataset.map(d => d.category.toUpperCase());

    // Preserve suppression masks visually; if count is "<10", paint safely as zero value metric metrics
    const numericData = dataset.map(d => d.count === '<10' ? 0 : parseInt(d.count, 10));

    // Custom data path colors matching your exact global theme variables configuration
    const primaryColorsPalette = meta.chart_type === 'pie' ?
      ['#26abe2', '#56bee7', '#9fdbee', '#96d6c2', '#003f5e'] : '#26abe2';

    chartsMap[meta.chart_id] = new Chart(ctx, {
      type: meta.chart_type === 'pie' ? 'doughnut' : 'bar',
      data: {
        labels: labels,
        datasets: [{
          data: numericData,
          backgroundColor: primaryColorsPalette,
          borderWidth: 0,
          borderRadius: meta.chart_type === 'pie' ? 0 : 5,
          hoverBackgroundColor: '#003f5e',
          barPercentage: 0.65
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: meta.chart_type === 'pie',
            position: 'bottom',
            labels: { boxWidth: 8, font: { size: 9, weight: '700' }, color: '#4b5563', padding: 12 }
          },
          tooltip: {
            backgroundColor: '#003f5e',
            titleFont: { size: 10, weight: '700' },
            bodyFont: { size: 11 },
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              label: (context) => {
                const calculatedCount = dataset[context.dataIndex].count;
                return ` Volume: ${calculatedCount} ${meta.units}`;
              }
            }
          }
        },
        scales: meta.chart_type === 'bar' ? {
          y: { beginAtZero: true, grid: { color: '#f3f4f6' }, ticks: { font: { size: 9, weight: '500' }, color: '#9ca3af' } },
          x: { grid: { display: false }, ticks: { font: { size: 9, weight: '600' }, color: '#4b5563' } }
        } : {}
      }
    });
  }

  function handleSearchQuery() {
    const query = document.getElementById('chart-search').value.toLowerCase().trim();
    const cards = document.querySelectorAll('.chart-card');
    let validatedItems = 0;

    cards.forEach(card => {
      const targetMatch = card.getAttribute('data-title').toLowerCase();
      if (targetMatch.includes(query)) {
        card.style.display = 'flex';
        validatedItems++;
      } else {
        card.style.display = 'none';
      }
    });

    document.getElementById('search-fallback').className = validatedItems === 0 ? 'flex' : 'hidden';
  }

  // 🛡️ STRONG BROWSER RUNTIME GATE: Executes instantly if document state is parsed, bypassing deferred module lockups
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeEngine);
  } else {
    initializeEngine();
  }
</script>
