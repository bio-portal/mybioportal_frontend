---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch and sort Team from YAML files
const allTeam = await getCollection('team');
const sortedTeam = allTeam.sort((a, b) => a.data.order - b.order);

// Fetch and sort News from Markdown files
const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<Layout title="BioPortal | Advancing Genomic Research">
  <nav class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md border-b border-gray-200/60">
    <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
      <a href={import.meta.env.BASE_URL} class="text-2xl font-bold text-brand-dark tracking-tight">
        BioPortal<span class="text-brand-cyan">.</span>
      </a>
      <div id="nav-links" class="hidden md:flex items-center space-x-8 opacity-0 transition-opacity duration-500 font-medium text-sm">
        <a href="#insights" class="text-gray-500 hover:text-brand-dark transition-colors">Insights</a>
        <a href="#team" class="text-gray-500 hover:text-brand-dark transition-colors">Our Team</a>
        <a href="mailto:david.morrison@ladydavis.ca" class="text-brand-cyan hover:text-brand-dark transition-colors font-bold">Contact</a>
      </div>
    </div>
  </nav>

  <header id="hero-section" class="min-h-screen flex flex-col justify-center pt-24 pb-12 px-6 max-w-5xl mx-auto text-center transition-all duration-700">
    <h1 class="text-5xl lg:text-7xl font-extrabold text-gray-900 tracking-tight leading-[1.1] mb-6">
      Advancing genomic research <br/> for <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">better treatments.</span>
    </h1>
    <p class="text-lg lg:text-xl text-gray-500 max-w-2xl mx-auto mb-16 leading-relaxed">
      BioPortal connects high-quality clinical data with world-class research. Select your path below to see how we can work together.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto w-full mb-12">
      <button data-role="participant" class="gateway-card group relative bg-white border-2 border-gray-100 rounded-3xl p-8 text-left outline-none transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-brand-cyan/10">
        <div class="w-14 h-14 rounded-2xl bg-brand-cyan/10 text-brand-cyan flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        <h3 class="text-3xl font-bold text-gray-900 mb-3 tracking-tight">I am a Participant</h3>
        <p class="text-gray-500 leading-relaxed mb-6">I have diabetes and want to contribute my data to help find better treatments.</p>
        <div class="text-brand-cyan font-bold flex items-center gap-2 group-hover:gap-4 transition-all">
          See participant benefits <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </button>

      <button data-role="researcher" class="gateway-card group relative bg-white border-2 border-gray-100 rounded-3xl p-8 text-left outline-none transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-brand-orange/10">
        <div class="w-14 h-14 rounded-2xl bg-brand-orange/10 text-brand-orange flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        </div>
        <h3 class="text-3xl font-bold text-gray-900 mb-3 tracking-tight">I am a Researcher</h3>
        <p class="text-gray-500 leading-relaxed mb-6">I am from academia or industry and want to request access to the BioPortal dataset.</p>
        <div class="text-brand-orange font-bold flex items-center gap-2 group-hover:gap-4 transition-all">
          View data catalog <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </button>
    </div>
  </header>

  <div id="content-wall" class="hidden opacity-0 transition-opacity duration-700 border-t border-gray-100">
    
    <section id="participant-view" class="hidden py-24 px-6 max-w-7xl mx-auto scroll-mt-20">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        <div class="lg:w-3/5">
          <span class="text-brand-cyan font-bold tracking-widest uppercase text-xs mb-4 block">Participant Pathway</span>
          <h2 class="text-4xl lg:text-5xl font-extrabold text-gray-900 mb-6 tracking-tight">Your data. Your health. Our future.</h2>
          <p class="text-lg text-gray-600 leading-relaxed mb-10">
            Every 3 minutes, a Canadian is diagnosed with Diabetes. Global biobanks currently lack diverse ethnic representation. By sharing a small amount of your time and health data, you become a critical part of the solution.
          </p>
          <div class="bg-white border border-gray-100 rounded-3xl p-8 shadow-lg shadow-brand-cyan/5 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-brand-cyan"></div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3 mt-2">Free Diabetic Eye Assessment</h3>
            <p class="text-gray-600 leading-relaxed">
              As a thank you, we offer Health Canada-approved diabetic retinopathy imaging <strong>at no cost</strong>. Within 5 minutes, your doctor receives a full report.
            </p>
          </div>
        </div>
        <div class="lg:w-2/5 w-full">
            <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 border border-gray-100 p-8 lg:sticky top-28">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Check Eligibility</h3>
                <p class="text-gray-500 mb-8">See if you qualify for the free screening.</p>
                <form class="space-y-6">
                    <input type="email" placeholder="name@example.com" class="w-full px-5 py-4 rounded-xl bg-gray-50 border border-gray-200 focus:bg-white focus:ring-2 focus:ring-brand-cyan outline-none transition-all">
                    <button type="submit" class="w-full bg-brand-dark hover:bg-gray-900 text-white font-bold py-4 rounded-xl transition-colors">See Next Steps</button>
                </form>
            </div>
        </div>
      </div>
    </section>

    <section id="researcher-view" class="hidden py-24 px-6 max-w-7xl mx-auto scroll-mt-20">
      <div class="text-center mb-16">
        <span class="text-brand-orange font-bold tracking-widest uppercase text-xs mb-4 block">Our platform so far</span>
        <h2 class="text-4xl lg:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">Open Science at Scale.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        <div class="bg-white rounded-3xl p-8 border-t-4 border-brand-cyan shadow-lg shadow-gray-100">
            <h3 class="text-5xl font-black text-gray-900 mb-2 tracking-tighter">5,985</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Patients w/ Clinical Data</p>
        </div>
        <div class="bg-white rounded-3xl p-8 border-t-4 border-brand-orange shadow-lg shadow-gray-100">
            <h3 class="text-5xl font-black text-gray-900 mb-2 tracking-tighter">43.6K</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Aliquots of Plasma</p>
        </div>
        <div class="bg-white rounded-3xl p-8 border-t-4 border-brand-green shadow-lg shadow-gray-100">
            <h3 class="text-5xl font-black text-gray-900 mb-2 tracking-tighter">6,284</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Aliquots of Urine</p>
        </div>
        <div class="bg-white rounded-3xl p-8 border-t-4 border-brand-dark shadow-lg shadow-gray-100">
            <h3 class="text-5xl font-black text-gray-900 mb-2 tracking-tighter">1,543</h3>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Patients w/ Proteomics</p>
        </div>
      </div>
    </section>

    <section id="insights" class="py-24 px-6 max-w-7xl mx-auto border-t border-gray-100 scroll-mt-20">
      <div class="mb-12">
        <span class="text-brand-orange font-bold tracking-widest uppercase text-xs mb-4 block">Insights</span>
        <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">News & Discoveries</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <article class="bg-white rounded-3xl p-8 border border-gray-100 shadow-soft hover:shadow-lg transition-all group flex flex-col">
            <div class="flex justify-between items-start mb-6">
              <span class="text-[10px] font-bold text-gray-400 uppercase">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <span class="text-[10px] font-bold px-2 py-1 rounded bg-brand-surface text-brand-orange">
                {post.data.tag}
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 leading-tight">{post.data.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-8 flex-grow">{post.data.excerpt}</p>
            
            <a href={`${import.meta.env.BASE_URL}news/${post.id}/`} class="text-brand-dark font-bold text-xs uppercase tracking-widest flex items-center gap-2 hover:gap-4 transition-all mt-auto">
              Read More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="team" class="py-24 px-6 max-w-7xl mx-auto border-t border-gray-100 bg-white/50 scroll-mt-20">
      <div class="text-center mb-16">
        <span class="text-brand-cyan font-bold tracking-widest uppercase text-xs mb-4 block">Our Team</span>
        <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Leadership & Expertise</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-12">
        {sortedTeam.map(member => (
          <div class="text-center group">
            <div class="w-32 h-32 rounded-full bg-surface mx-auto mb-4 overflow-hidden border-4 border-white shadow-soft group-hover:scale-105 transition-transform duration-500 relative flex items-center justify-center">
               <div class="absolute inset-0 flex items-center justify-center text-brand-cyan bg-brand-cyan/5">
                 <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
               </div>
               {member.data.image && <img src={member.data.image} alt={member.data.name} class="w-full h-full object-cover relative z-10" onerror="this.style.display='none'" />}
            </div>
            <h3 class="font-bold text-gray-900 leading-tight">{member.data.name}</h3>
            <p class="text-[10px] font-bold text-brand-cyan uppercase tracking-widest mt-1">{member.data.role}</p>
          </div>
        ))}
      </div>
    </section>

    <footer class="bg-brand-dark text-white py-16 px-6 text-center">
        <div class="text-2xl font-bold mb-2">BioPortal<span class="text-brand-cyan">.</span></div>
        <p class="text-gray-400 text-sm mb-8">Jewish General Hospital & McGill University</p>
        <div class="text-[10px] text-gray-500 uppercase tracking-widest">© 2026 BioPortal Research Group. Built with Astro.</div>
    </footer>

  </div>
</Layout>

<style>
  @reference "../styles/global.css";
  .selected {
    @apply border-brand-dark bg-gray-50 scale-[0.98] shadow-inner;
  }
</style>

<script>
  // Handles the dual-pathway gateway
  const buttons = document.querySelectorAll('.gateway-card');
  const contentWall = document.getElementById('content-wall');
  const pView = document.getElementById('participant-view');
  const rView = document.getElementById('researcher-view');
  const navLinks = document.getElementById('nav-links');
  const heroSection = document.getElementById('hero-section');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const role = btn.getAttribute('data-role');

      // Reset everything
      buttons.forEach(b => b.classList.remove('selected'));
      pView.classList.add('hidden');
      rView.classList.add('hidden');

      // Select active card
      btn.classList.add('selected');
      if (role === 'participant') pView.classList.remove('hidden');
      if (role === 'researcher') rView.classList.remove('hidden');

      // Reveal content
      contentWall.classList.remove('hidden');
      navLinks.classList.remove('hidden');
      
      setTimeout(() => {
        contentWall.classList.remove('opacity-0');
        navLinks.classList.remove('opacity-0');
        heroSection.classList.remove('min-h-screen');
        
        const targetView = role === 'participant' ? pView : rView;
        targetView.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
    });
  });
</script>