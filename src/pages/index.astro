---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const homeData = await getEntry('pages', 'home');
const allTeam = await getCollection('team');
const sortedTeam = allTeam.sort((a, b) => a.data.order - b.data.order);
const allNews = await getCollection('news');
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<Layout title="BioPortal | Advancing Genomic Research">
  <nav class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md border-b border-gray-200/60">
    <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
      <a href={`${baseUrl}/`} class="flex items-center group">
        <img src={`${baseUrl}/logos/BioPortal_Primary_Color.svg`} alt="BioPortal Logo" class="h-8 w-auto group-hover:-translate-y-0.5 transition-transform" onerror="this.style.display='none'" />
      </a>
      <div class="hidden md:flex items-center space-x-8 font-medium text-sm">
        <a href="#insights" class="text-gray-500 hover:text-brand-dark transition-colors">Insights</a>
        <a href="#team" class="text-gray-500 hover:text-brand-dark transition-colors">Our Team</a>
        <a href="mailto:david.morrison@ladydavis.ca" class="text-brand-blue-deep hover:text-brand-dark transition-colors font-bold">Contact</a>
      </div>
    </div>
  </nav>

  <main>
    <Hero content={homeData.data.hero} />
    <TrustBar content={homeData.data.trustBar} />

    <section id="insights" class="py-16 px-6 max-w-7xl mx-auto scroll-mt-20">
      <div class="mb-12 flex justify-between items-end">
        <div>
            <span class="text-brand-orange-mid font-bold tracking-widest uppercase text-xs mb-4 block">Latest Insights</span>
            <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">News & Discoveries</h2>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {latestNews.map(post => (
          <article class="bg-white rounded-[2rem] p-8 border border-gray-100 shadow-soft hover:shadow-2xl transition-all group flex flex-col">
            <div class="flex justify-between items-start mb-6">
              <span class="text-[10px] font-bold text-gray-400 uppercase">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <span class="text-[10px] font-bold px-3 py-1 rounded-full bg-brand-orange-mid/10 text-brand-orange-deep">{post.data.tag}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 leading-tight group-hover:text-brand-orange-deep transition-colors">{post.data.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-8 flex-grow line-clamp-3">{post.data.excerpt}</p>
            <a href={`${baseUrl}/news/${post.id}/`} class="text-brand-dark font-bold text-xs uppercase tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all mt-auto">
              Read Insight <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="team" class="py-16 px-6 max-w-7xl mx-auto border-t border-gray-100 bg-white/50 scroll-mt-20">
      <div class="text-center mb-16">
        <span class="text-brand-blue-mid font-bold tracking-widest uppercase text-xs mb-4 block">Leadership</span>
        <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Project Governance</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-12">
        {sortedTeam.map(member => (
          <div class="text-center group">
            <div class="w-40 h-40 rounded-full bg-surface mx-auto mb-6 overflow-hidden border-8 border-white shadow-xl group-hover:scale-105 transition-transform duration-500 relative flex items-center justify-center">
               <div class="absolute inset-0 flex items-center justify-center text-brand-blue-deep bg-brand-blue-deep/5">
                 <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
               </div>
               {member.data.image && <img src={`${baseUrl}${member.data.image}`} alt={member.data.name} class="w-full h-full object-cover relative z-10" onerror="this.style.display='none'" />}
            </div>
            <h3 class="text-xl font-bold text-gray-900 leading-tight mb-1">{member.data.name}</h3>
            <p class="text-xs font-bold text-brand-blue-deep uppercase tracking-widest">{member.data.role}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <footer class="bg-brand-dark text-white py-20 px-6 text-center">
      <div class="text-2xl font-bold mb-2 tracking-tight">BioPortal<span class="text-brand-blue-deep">.</span></div>
      <p class="text-gray-400 text-sm mb-12">Jewish General Hospital & McGill University</p>
      <div class="text-[10px] text-gray-500 uppercase tracking-[0.3em] font-bold">© 2026 BioPortal Research Group</div>
  </footer>
</Layout>
