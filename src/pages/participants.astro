---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const pageData = await getEntry('pages', 'participants');

// Robust content fallback architecture preventing schema structural failures
const hero = pageData?.data?.hero || {
  tagline: "Participant Portal",
  headline: "Advance Medicine Through",
  gradientText: "Genetic Insight",
  description: "Safely contribute to groundbreaking healthcare insights right here in Montreal."
};
const steps = pageData?.data?.steps || [];
---
<Layout title="Join BioPortal | Advancing Diabetes Research" navType="minimal">
  <div class="fixed top-0 inset-x-0 h-[600px] bg-gradient-to-br from-brand-green-bright/5 via-brand-teal/5 to-transparent -z-10"></div>

  <main class="max-w-6xl mx-auto px-6 pt-4 pb-24 relative z-10">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">

      <div class="lg:w-7/12 space-y-12">

        <div>
          <span class="text-brand-green-bright font-bold tracking-widest uppercase text-xs mb-4 block">{hero.tagline}</span>
          <h1 class="text-4xl lg:text-6xl font-extrabold text-gray-900 tracking-tight leading-[1.1] mb-6">
            {hero.headline}<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-green-bright to-brand-teal">{hero.gradientText}</span>
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed font-medium">{hero.description}</p>
        </div>

        <div class="space-y-6">
          <h3 class="text-xs font-extrabold text-gray-400 uppercase tracking-widest pl-1">Why Join BioPortal</h3>

          <div class="grid grid-cols-1 gap-4">
            <div class="bg-gradient-to-br from-brand-dark to-slate-900 rounded-[2rem] p-8 text-white shadow-xl relative overflow-hidden group border border-slate-800">
              <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-green-bright/10 rounded-full blur-3xl group-hover:bg-brand-green-bright/20 transition-all duration-500"></div>
              <div class="relative z-10 flex gap-5 items-start">
                <div class="w-12 h-12 bg-brand-green-bright/20 text-brand-green-bright border border-brand-green-bright/30 rounded-2xl flex items-center justify-center shrink-0 mt-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <div>
                  <h4 class="text-xl font-extrabold text-white mb-2 tracking-tight">Your Data Returned to You</h4>
                  <p class="text-slate-300 text-sm leading-relaxed font-medium">
                    Gain exclusive, secure portal access to view your complete processed clinical datasets and multi-omics metabolic mapping insights. Your biology, back in your hands.
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-[2rem] p-8 border border-gray-100 shadow-soft hover:border-brand-green-bright/20 transition-all duration-300 flex gap-5 items-start group">
              <div class="w-12 h-12 bg-brand-green-bright/10 text-brand-green-bright rounded-2xl flex items-center justify-center shrink-0 mt-1 transition-colors group-hover:bg-brand-green-bright/20">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <div>
                <h4 class="text-lg font-bold text-gray-900 mb-1.5 tracking-tight">Direct Localized Health Impact</h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  Your completely voluntary contributions directly empower localized scientific researchers across Montreal clinical pipelines to crack complex tracking signals in diabetes care models.
                </p>
              </div>
            </div>

            <div class="bg-white rounded-[2rem] p-8 border border-gray-100 shadow-soft hover:border-brand-green-bright/20 transition-all duration-300 flex gap-5 items-start group">
              <div class="w-12 h-12 bg-brand-teal/10 text-brand-teal rounded-2xl flex items-center justify-center shrink-0 mt-1 transition-colors group-hover:bg-brand-teal/20">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              </div>
              <div>
                <h4 class="text-lg font-bold text-gray-900 mb-1.5 tracking-tight">Rigorous Security Safeguards</h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  Data custody operates under premium double-anonymization protocols. Your dynamic identity is split from biological materials, giving you complete safety and peace of mind.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-4">
          <h3 class="text-xs font-extrabold text-gray-400 uppercase tracking-widest mb-8 pl-1">How Participation Works</h3>
          <div class="space-y-6 relative pl-4 border-l-2 border-gray-100 ml-5">
            {steps.map((step: any, index: number) => (
              <div class="relative group">
                <div class="absolute -left-[37px] top-0 w-8 h-8 rounded-full bg-white border-2 border-gray-200 text-gray-400 font-extrabold text-xs flex items-center justify-center transition-all group-hover:border-brand-green-bright group-hover:text-brand-green-bright group-hover:scale-105 shadow-sm">
                  {index + 1}
                </div>
                <div class="pl-4 pb-2">
                  <h4 class="font-bold text-gray-900 text-base mb-0.5 tracking-tight">{step.title}</h4>
                  <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="lg:w-5/12 w-full lg:sticky lg:top-28 space-y-6">

        <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-brand-green-bright/5 border border-gray-100 p-8 lg:p-10 relative overflow-hidden">
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-teal/10 rounded-full blur-3xl"></div>

          <div class="relative z-10">
            <h3 class="text-2xl font-black text-brand-dark mb-1 tracking-tight">Eligibility Check</h3>
            <p class="text-gray-400 mb-6 text-sm font-medium">Answer 3 quick screening targets to query study availability inside Montreal.</p>

            <form class="space-y-4">
              <label class="group flex items-center justify-between p-4 rounded-xl border border-gray-200 bg-surface/50 hover:border-brand-green-bright/40 hover:bg-white transition-all cursor-pointer shadow-inner">
                <span class="text-xs font-bold text-gray-700 pr-2 leading-tight">Are you 18 years or older?</span>
                <input type="checkbox" class="w-5 h-5 rounded border-gray-300 text-brand-green-bright focus:ring-brand-green-bright cursor-pointer shrink-0" />
              </label>
              <label class="group flex items-center justify-between p-4 rounded-xl border border-gray-200 bg-surface/50 hover:border-brand-green-bright/40 hover:bg-white transition-all cursor-pointer shadow-inner">
                <span class="text-xs font-bold text-gray-700 pr-2 leading-tight">Do you live in the Greater Montreal area?</span>
                <input type="checkbox" class="w-5 h-5 rounded border-gray-300 text-brand-green-bright focus:ring-brand-green-bright cursor-pointer shrink-0" />
              </label>
              <label class="group flex items-center justify-between p-4 rounded-xl border border-gray-200 bg-surface/50 hover:border-brand-green-bright/40 hover:bg-white transition-all cursor-pointer shadow-inner">
                <span class="text-xs font-bold text-gray-700 pr-2 leading-tight">Diagnosed with Type 1 or Type 2 Diabetes?</span>
                <input type="checkbox" class="w-5 h-5 rounded border-gray-300 text-brand-green-bright focus:ring-brand-green-bright cursor-pointer shrink-0" />
              </label>

              <div class="pt-2">
                <label class="block text-[10px] uppercase tracking-widest font-black text-gray-400 mb-2 ml-1">Your Email Address</label>
                <input type="email" placeholder="doctor.smith@mcgill.ca" class="w-full px-5 py-4 rounded-xl bg-surface border border-gray-200 focus:border-brand-green-bright focus:bg-white focus:ring-2 focus:ring-brand-green-bright/20 transition-all outline-none text-sm font-medium shadow-inner" />
              </div>

              <button type="button" class="w-full py-4 rounded-xl bg-brand-green-bright text-white font-bold text-sm uppercase tracking-widest shadow-lg shadow-brand-green-bright/20 hover:bg-brand-green-mid hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2 mt-4 cursor-pointer">
                Check My Eligibility
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
            </form>

            <p class="mt-6 text-[11px] text-gray-400 text-center leading-relaxed font-medium">
              By validating, you authorize secure operations contact loops. Read our global open science <a href={`${baseUrl}/privacy`} class="text-brand-green-bright underline hover:text-brand-dark transition-colors font-bold">Privacy Policy</a>.
            </p>
          </div>
        </div>

        <div class="bg-white rounded-[2.5rem] border border-gray-100 p-8 shadow-soft">
          <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-4 block text-center">Strategic Operational Core Ecosystem</span>

          <div class="grid grid-cols-2 gap-4 items-center justify-items-center opacity-60 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500">
            <img src={`${baseUrl}/logos/jgh-logo.png`} alt="Jewish General Hospital" class="h-8 max-w-full object-contain" onerror="this.style.display='none'" />
            <img src={`${baseUrl}/logos/cqdm-logo.png`} alt="CQDM Consortium" class="h-6 max-w-full object-contain" onerror="this.style.display='none'" />
            <div class="text-[11px] font-black text-brand-dark/40 tracking-wider font-sans uppercase">McGill University</div>
            <div class="text-[11px] font-black text-brand-dark/40 tracking-wider font-sans uppercase">Lady Davis Institute</div>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<style>
  /* Interactivity override layers preserving crisp dark border focus rings on checkboxes labels */
  label:focus-within {
    border-color: var(--color-brand-green-bright) !important;
    background-color: #ffffff !important;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;
  }
</style>
