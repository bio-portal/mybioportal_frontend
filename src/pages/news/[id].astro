---
// src/pages/news/[id].astro
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Tell Astro to generate a page for every markdown file in the 'news' collection
export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

// 2. Get the specific post data for the current page
const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | BioPortal Insights`}>
  
  <div class="absolute top-0 inset-x-0 h-[400px] bg-gradient-to-b from-brand-orange/5 to-transparent -z-10"></div>

  <nav class="max-w-7xl mx-auto px-6 py-8 flex justify-between items-center">
    <a href="/" class="text-2xl font-bold text-brand-dark tracking-tight hover:opacity-80 transition-opacity">
      Bio<span class="font-normal">Portal</span>
    </a>
    <a href="/#insights" class="text-brand-orange font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to Insights
    </a>
  </nav>

  <main class="max-w-3xl mx-auto px-6 pt-12 pb-24">
    
    <header class="mb-12 border-b border-gray-100 pb-12">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-xs font-bold px-3 py-1 rounded-md bg-brand-orange/10 text-brand-orange uppercase tracking-widest">
          {post.data.tag}
        </span>
        <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>
      
      <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight">
        {post.data.title}
      </h1>
    </header>

    <article class="text-lg text-gray-600 leading-relaxed space-y-6 article-content">
      <Content />
    </article>

  </main>

  <footer class="bg-brand-dark text-white py-12 px-6 text-center mt-12">
      <div class="text-xl font-bold mb-2">BioPortal<span class="text-brand-cyan">.</span></div>
      <p class="text-gray-400 text-xs mb-0">Jewish General Hospital & McGill University</p>
  </footer>
</Layout>

<style>
  @reference "../../styles/global.css";

  /* Since we are rendering raw Markdown, we need to style the tags (h2, p, a, ul) 
    that Astro generates automatically from your .md files. 
  */
  .article-content :global(h2) {
    @apply text-3xl font-bold text-gray-900 mt-12 mb-6 tracking-tight;
  }
  .article-content :global(h3) {
    @apply text-2xl font-bold text-gray-900 mt-8 mb-4 tracking-tight;
  }
  .article-content :global(p) {
    @apply mb-6;
  }
  .article-content :global(a) {
    @apply text-brand-cyan font-semibold hover:text-brand-dark transition-colors underline underline-offset-2;
  }
  .article-content :global(ul) {
    @apply list-disc list-outside ml-6 mb-6 space-y-2;
  }
  .article-content :global(blockquote) {
    @apply border-l-4 border-brand-orange pl-6 py-2 my-8 text-xl italic text-gray-500 bg-brand-orange/5 rounded-r-2xl;
  }
  .article-content :global(strong) {
    @apply font-bold text-gray-900;
  }
</style>
