---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const {
  footerData,
  lang = 'en' // Catch the active language context token
} = Astro.props;

// Establish language-aware route pathing
const langPrefix = lang === 'en' ? '' : '/fr';
---
<footer class="bg-brand-dark text-white py-20 px-6 text-center mt-auto border-t border-white/5">
  <div class="max-w-4xl mx-auto flex flex-col items-center">

    <div class="text-2xl font-bold mb-2 tracking-tight">
      {footerData.title}<span class="text-brand-blue-deep">{footerData.titlePunctuation}</span>
    </div>
    <p class="text-gray-400 text-sm mb-10">{footerData.subtitle}</p>

    {/* Social Icons */}
    <div class="flex items-center gap-6 mb-10">
      <a href="https://x.com/bioportal_hgj" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-brand-blue-deep transition-all duration-300" aria-label="X (Twitter)">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/company/112363978" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-brand-blue-deep transition-all duration-300" aria-label="LinkedIn">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>

   {/* Footer Navigation Links */}
    <div class="flex flex-col items-center gap-5 mb-12 w-full text-center">

      <a href={`${baseUrl}${langPrefix}${footerData.privacyLinkHref}`} class="text-sm font-medium text-gray-400 hover:text-white transition-colors">
        {footerData.privacyLinkText}
      </a>

      <a href={`${baseUrl}${langPrefix}/faq/`} class="text-sm font-medium text-gray-400 hover:text-white transition-colors">
        {footerData.faqLinkText}
      </a>

      {/* Added a tiny bit of top margin (mt-2) to slightly separate the contact from the pages */}
      <a href="mailto:access.bioportal@ladydavis.ca" class="text-sm font-medium text-gray-400 hover:text-white transition-colors flex items-center gap-2 group mt-2">
        <svg class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        {footerData.contactText} (access.bioportal@ladydavis.ca)
      </a>

    </div>


    <div class="text-[10px] text-gray-500 uppercase tracking-[0.3em] font-bold">
      {footerData.copyright}
    </div>

  </div>
</footer>
